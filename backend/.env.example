PORT=5000
CORS_ORIGIN=http://localhost:3000

# MongoDB (current backend uses MongoDB)
MONGO_URI=mongodb://localhost:27017/enterprisehr
# Or: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/enterprisehr?retryWrites=true&w=majority

# MySQL (for future use if you switch from MongoDB)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=enterprisehr

JWT_SECRET=enterprisehr_secret

# Email (NodeMailer Gmail SMTP)
# For Gmail, use an App Password (recommended) not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourcompanyhr@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="EnterpriseHR <yourcompanyhr@gmail.com>"
COMPANY_NAME=EnterpriseHR
