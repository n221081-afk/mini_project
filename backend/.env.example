PORT=5001
# Use mongodb+srv (recommended) OR standard format if you get querySrv ECONNREFUSED
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Standard format (when SRV/DNS fails): mongodb://user:pass@host1:27017,host2:27017/dbname?ssl=true&authSource=admin
JWT_SECRET=your-secure-jwt-secret-key-change-in-production
